#!/bin/bash
#SBATCH --account=project_2019517
#SBATCH --partition=gpu
#SBATCH --gres=gpu:v100:1
#SBATCH --time=4:00:00
#SBATCH --mem=128G
#SBATCH --cpus-per-task=4
#SBATCH --job-name=moment_cached
#SBATCH --output=/users/hamehdi/projects/sleepfm-mesa/logs/moment_cached_%j.log

# Usage: sbatch run_moment_cached.slurm <MODALITY>
# MODALITY one of: EEG_ONLY, ECG_ONLY, EEG_ECG, BAS, BAS_EKG, BAS_EKG_RESP, BAS_EKG_RESP_EMG
#
# Trains a linear classification head on pre-computed MOMENT embeddings.
# Embeddings must exist (generated by run_moment_embed.slurm).
# Resumable: re-submitting this script continues from latest.pth automatically.
set -e
MODALITY=${1:?Usage: sbatch run_moment_cached.slurm <MODALITY>}
FOLD_KEY=${2:-fold_0}

cd /users/hamehdi/projects/sleepfm-mesa
export HDF5_USE_FILE_LOCKING=FALSE
export TMPDIR=/scratch/project_2019517/tmp
mkdir -p "$TMPDIR"
source /scratch/project_2019517/miniconda3/etc/profile.d/conda.sh
conda activate sleepfm_env

LATEST_CKPT="/scratch/project_2019517/moment/checkpoints/${MODALITY}/${FOLD_KEY}/latest.pth"
if [ -f "$LATEST_CKPT" ]; then
    echo "===== Resuming MOMENT cached head training (${MODALITY}) from ${LATEST_CKPT} ====="
else
    echo "===== Starting MOMENT cached head training (${MODALITY}) from scratch ====="
fi
python scripts/finetune_moment_cached.py --modality ${MODALITY} --fold_key ${FOLD_KEY}

echo "===== Evaluating MOMENT cached (${MODALITY}) ====="
python scripts/evaluate_moment_cached.py --modality ${MODALITY} --fold_key ${FOLD_KEY}

echo "========== DONE (${MODALITY}) =========="
